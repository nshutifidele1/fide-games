
{
  "entities": {
    "Game": {
      "title": "Game",
      "description": "A game available on the Fide platform",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "coverUrl": { "type": "string", "format": "uri" },
        "downloadUrl": { "type": "string", "format": "uri" },
        "trailerUrl": { "type": "string", "format": "uri" },
        "zipPassword": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "coverUrl", "downloadUrl", "category"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Game category",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/games/{gameId}": {
      "schema": "#/entities/Game",
      "description": "Collection of available games"
    },
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profile records"
    },
    "/categories/{categoryId}": {
      "schema": "#/entities/Category",
      "description": "Collection of game categories"
    }
  }
}
